# ================================================================
# PyClimaExplorer — Environment Variables
# ================================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in every value marked with <YOUR_VALUE>
# 3. NEVER commit .env to git (it is already in .gitignore)
# ================================================================

# ── Supabase ─────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://<YOUR_PROJECT_ID>.supabase.co
SUPABASE_ANON_KEY=<YOUR_ANON_KEY>
SUPABASE_SERVICE_KEY=<YOUR_SERVICE_ROLE_KEY>

# ── LLM API (at least one required for AI Analyst feature) ───────
# Get Anthropic key: https://console.anthropic.com/
ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_KEY>

# Get OpenAI key: https://platform.openai.com/
OPENAI_API_KEY=<YOUR_OPENAI_KEY>

# Which provider to use: "anthropic" or "openai"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-haiku-20241022

# ── Server URLs ──────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:8501

# ── Data directory ───────────────────────────────────────────────
# Where your .nc files are stored (relative to backend/)
DATA_DIR=../data
